# Ollama local
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
# Si defines OLLAMA_CHAT_URL, tiene prioridad sobre host+puerto
OLLAMA_MODEL=minimax-m2.7:cloud
OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat

# Opcional: limita el texto enviado a la IA
MAX_TRANSCRIPT_CHARS_FOR_AI=50000
OLLAMA_CHUNK_SIZE=12000
OLLAMA_MAX_CHUNKS=6

# Puerto del servidor
PORT=3000

# Servidor local de la app web con proxy de transcript
CLIPTUBE_WEB_HOST=127.0.0.1
CLIPTUBE_WEB_PORT=4174

# Web app / desktop parity
# La app web y la desktop pueden derivar la URL efectiva desde host+puerto.
# Si usas un endpoint completo, ese override tiene prioridad.

# UI / screenshots
# Fuerza el idioma de la interfaz para sacar capturas (es, en, pt, fr, de, ja, zh-Hans, ru, ar, hi)
CLIPTUBE_UI_LANGUAGE=en

# GitHub
# Usa estos valores solo en tu .env local, nunca subas tokens reales al repo.
GITHUB_USERNAME=tu_usuario
GH_TOKEN=tu_token
